        "/v1/reports/{id}/resolve": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Only the report owner can resolve. Use this when the pet was returned to its owner.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "reports"
