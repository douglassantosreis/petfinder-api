    "definitions": {
        "handler.ConversationResponse": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string",
                    "example": "64a1f2c3d4e5f6789abcdef2"
                },
                "lastMessageAt": {
                    "type": "string",
                    "example": "2024-01-15T10:30:00Z"
                },
                "participants": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "64a1f2c3d4e5f6789abcdef1",
                        "64a1f2c3d4e5f6789abcdef3"
                    ]
                },
                "reportId": {
                    "type": "string",
                    "example": "64a1f2c3d4e5f6789abcdef0"
                }
            }
        },
        "handler.CreateReportRequest": {
            "type": "object",
            "properties": {
                "characteristics": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "golden",
                        "male",
                        "large"
