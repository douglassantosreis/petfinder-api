GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/v1/auth/oauth/google/callback

# Used by "make run" (local API against Docker MongoDB)
MONGO_URI=mongodb://admin:admin@localhost:27017/?authSource=admin

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# "local" (default) or "s3"
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3
# S3_BUCKET=petfinder-uploads
# S3_REGION=us-east-1
# S3_ENDPOINT=           # leave empty for AWS; set for MinIO (e.g. http://localhost:9000)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Base URL where uploaded files are publicly reachable.
# For local: keep as localhost (Google Vision won't reach it — use ngrok for real tests).
# For production: CloudFront, S3 or Cloudflare R2 public URL.
UPLOAD_BASE_URL=http://localhost:8080
